      "name": "Conti",
      "malware_types": ["ransomware"],
      "is_family": false,
      "aliases": ["Conti RaaS", "S0575"],
      "first_seen": "2019-10-01T00:00:00Z",
      "last_seen": "2022-05-19T00:00:00Z",
      "description": "Conti is a Ransomware-as-a-Service (RaaS) operated by Wizard Spider. It uses ChaCha20/AES-256 symmetric encryption with RSA-4096 key wrapping, 32-threaded parallel file encryption, double extortion via data leak site, and Cobalt Strike for C2. Active October 2019 to May 2022."
    },

    {
      "type": "threat-actor",
      "spec_version": "2.1",
      "id": "threat-actor--b2c3d4e5-0002-0002-0002-000000000002",
      "created": "2026-03-10T00:00:00Z",
      "modified": "2026-03-10T00:00:00Z",
      "name": "Wizard Spider",
      "aliases": ["ITG23", "Gold Blackburn", "DEV-0193", "TEMP.MixMaster", "GRIM SPIDER", "UNC1878"],
      "sophistication": "advanced",
      "resource_level": "organization",
      "primary_motivation": "financial-gain",
      "description": "Russian-speaking cybercriminal group attributed to Conti, Ryuk, TrickBot, and BazarLoader. Assessed by UK officials to have ties to Russian government intelligence services."
    },

